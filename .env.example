# ─────────────────────────────────────────────
#  PrepHQ Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# MongoDB Atlas URI
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/prephq?retryWrites=true&w=majority

# Admin Key — MUST be strong and secret
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Example:  a3f8c2e1b9d047f6a2c5e8b1d4f7a0c3e6b9d2f5a8c1e4b7d0f3a6c9e2b5d8f1
ADMIN_KEY=REPLACE_WITH_GENERATED_KEY

# Port (Render sets this automatically — leave as 3000 for local)
PORT=3000
